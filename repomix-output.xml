echo "Configuring GitLab CI/CD variables..."

# Check if PROXMOX_HOST is set
if [[ -z "$PROXMOX_HOST" ]]; then
    echo "ERROR: PROXMOX_HOST environment variable is not set"
    echo "Please run: export PROXMOX_HOST=77.50.132.85"
    exit 1
