# Remote Proxmox access.
PROXMOX_HOST=77.50.132.85
PROXMOX_USER=root
REMOTE_DIR=/root/llm-lab

# Proxmox resources.
# Keep the template and LLM VM on the fast SSD pool; keep monitoring on local-lvm.
TEMPLATE_STORAGE=SSD-VMs
LLM_STORAGE=SSD-VMs
MONITORING_STORAGE=local-lvm
TEMPLATE_VMID=9000
UBUNTU_IMAGE_URL=https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img
UBUNTU_IMAGE_PATH=/var/lib/vz/template/qcow2/ubuntu-noble.img
PREPARED_IMAGE_PATH=/var/lib/vz/template/qcow2/ubuntu-noble-llm-prepared.img
SSH_PUBLIC_KEY=/root/.ssh/id_rsa.pub

# Networking.
WAN_BRIDGE=vmbr0
INTERNAL_BRIDGE=vmbr1
INTERNAL_CIDR=10.10.10.1/24
INTERNAL_SUBNET=10.10.10.0/24
INTERNAL_GATEWAY=10.10.10.1
DNS_SERVER=1.1.1.1

# LLM VM.
LLM_VMID=110
LLM_NAME=llm-server
LLM_IP=10.10.10.50
LLM_PREFIX=24
LLM_MEMORY_MB=16384
LLM_CORES=4
LLM_SYSTEM_DISK_GB=40
LLM_DATA_DISK_GB=120

# Monitoring VM.
MONITORING_VMID=120
MONITORING_NAME=monitoring-vm
MONITORING_IP=10.10.10.60
MONITORING_PREFIX=24
MONITORING_MEMORY_MB=4096
MONITORING_CORES=2
MONITORING_SYSTEM_DISK_GB=40
MONITORING_DATA_DISK_GB=100

# Guest access.
GUEST_USER=ubuntu
SSH_OPTS="-o StrictHostKeyChecking=accept-new -o ServerAliveInterval=30"
